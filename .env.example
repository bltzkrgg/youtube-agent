# AI Clipper Configuration
# Set to 'true' for testing without real downloads or API calls
DRY_RUN=true
NODE_ENV=development

# OpenRouter API key for LLM agents
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model per-agent (default: anthropic/claude-3-haiku if not set)
# See all models at: https://openrouter.ai/models
CLIP_PLANNER_MODEL=anthropic/claude-3-5-sonnet
METADATA_MODEL=anthropic/claude-3-haiku

# Telegram bot for clip review and approval
# Create bot via @BotFather to get token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Send message to @userinfobot to get your chat ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Enable or disable advanced processing agents
# Set to 'false' to disable (default: enabled)
ENABLE_MOMENT_SCORING=true
ENABLE_CRITIC=true
ENABLE_CAPTION_AGENT=true
ENABLE_REFRAME_AGENT=true

# Whisper transcription model size
# Options: tiny, base, small, medium, large
# Larger models are more accurate but slower
WHISPER_MODEL=base

# Scene detection threshold
# Default: 27.0
# Lower values = more sensitive (more scenes detected)
SCENE_DETECT_THRESHOLD=27.0

# yt-dlp format string for video download
# Default: best quality MP4 with separate video/audio streams
YTDLP_FORMAT=bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best

# Optional: Extract cookies from browser for age-restricted videos
# Options: chrome, firefox, safari, edge
# Leave commented out if not needed
# YTDLP_COOKIES_FROM_BROWSER=chrome

# Maximum retry attempts for failed operations
MAX_RETRY=3

# Default timeout in milliseconds (30 minutes)
TIMEOUT_DEFAULT=1800000

# Output video dimensions (vertical format for TikTok/Shorts)
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30

# Directory paths (relative to project root)
OUTPUT_DIR=./output
CACHE_DIR=./cache
MEMORY_DIR=./memory
LOG_DIR=./logs

# Cache time-to-live in hours
CACHE_TTL_HOURS=6

# Days to keep rejected videos before cleanup
REJECTED_VIDEO_TTL_DAYS=7

# Legacy UGC Generator Pipeline (disabled by default)
# YOUTUBE_API_KEY=your_youtube_api_key_here
# RESEARCH_MODEL=anthropic/claude-3-haiku
# TTS_VOICE=id-ID-ArdiNeural
# TTS_RATE=+0%
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_VIDEO_MODEL=veo-1.0
# VISUAL_PROMPT_MODEL=google/gemini-flash-1.5
# BG_MUSIC_PATH=

