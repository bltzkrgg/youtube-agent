# ─── Mode ────────────────────────────────────────────────────────────────────
DRY_RUN=true
NODE_ENV=development

# ─── AI (OpenRouter) ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3-haiku

# ─── OpenAI TTS (Voiceover) ───────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
TTS_MODEL=tts-1
# Voice options: alloy, echo, fable, onyx, nova, shimmer
# onyx = dramatic masculine, nova = expressive female
TTS_VOICE=onyx
TTS_SPEED=1.0

# ─── Pexels (Stock Footage) ───────────────────────────────────────────────────
PEXELS_API_KEY=your_pexels_api_key_here

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Google Drive ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here
# Token disimpan otomatis di token.json setelah auth pertama kali

# ─── Retry & Timeout ──────────────────────────────────────────────────────────
MAX_RETRY=3
TIMEOUT_RESEARCH=300000
TIMEOUT_CLIP=1800000
TIMEOUT_UPLOAD=600000
TIMEOUT_DEFAULT=60000

# ─── Video Config ─────────────────────────────────────────────────────────────
VIDEO_MAX_DURATION=60
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30

# ─── Content ──────────────────────────────────────────────────────────────────
CONTENT_NICHE=fakta unik indonesia
CONTENT_LANGUAGE=id
CONTENT_COUNTRY=ID

# ─── Paths ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
CACHE_DIR=./cache
MEMORY_DIR=./memory
LOG_DIR=./logs

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL_HOURS=6

# ─── Cleanup ──────────────────────────────────────────────────────────────────
REJECTED_VIDEO_TTL_DAYS=7
