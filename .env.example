# ─── Mode ────────────────────────────────────────────────────────────────────
DRY_RUN=true
NODE_ENV=development

# ─── AI — OpenRouter ─────────────────────────────────────────────────────────
# Dapatkan di: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model LLM per-agent (default: anthropic/claude-3-haiku jika tidak di-set)
# Lihat semua model di: https://openrouter.ai/models
RESEARCH_MODEL=anthropic/claude-3-haiku
SCRIPT_MODEL=anthropic/claude-3-5-sonnet
METADATA_MODEL=anthropic/claude-3-haiku
VISUAL_PROMPT_MODEL=google/gemini-flash-1.5

# ─── YouTube Data API v3 ──────────────────────────────────────────────────────
# Google Cloud Console → Enable "YouTube Data API v3" → Create API Key
# Kuota: 10.000 units/hari (gratis). Pipeline ini ~100 units/hari.
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Edge TTS (Voiceover) — gratis, tidak butuh API key ──────────────────────
# Suara Indonesia: id-ID-ArdiNeural (maskulin), id-ID-GadisNeural (feminin)
TTS_VOICE=id-ID-ArdiNeural
# Rate: +0% normal, +10% lebih cepat, -10% lebih lambat
TTS_RATE=+0%

# ─── Google AI Studio (AI Video Generation — Veo) ────────────────────────────
# Dapatkan dari: https://aistudio.google.com → Get API Key
GOOGLE_API_KEY=your_google_api_key_here
# Model video: veo-1.0 (default)
GOOGLE_VIDEO_MODEL=veo-1.0

# ─── Background Music (Opsional) ─────────────────────────────────────────────
# Letakkan file mp3 bebas royalti, akan di-mix 12% volume di bawah voiceover
# Kosongkan jika tidak mau ada BGM
BG_MUSIC_PATH=

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Buat bot via @BotFather → dapatkan token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Kirim pesan ke @userinfobot untuk mendapatkan chat ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Retry & Timeout ──────────────────────────────────────────────────────────
MAX_RETRY=3
TIMEOUT_RESEARCH=300000
TIMEOUT_VISUAL=3600000
TIMEOUT_CLIP=1800000
TIMEOUT_UPLOAD=600000
TIMEOUT_DEFAULT=1800000

# ─── Video Config ─────────────────────────────────────────────────────────────
VIDEO_MAX_DURATION=55
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30

# ─── Content ──────────────────────────────────────────────────────────────────
CONTENT_NICHE=fakta unik indonesia
CONTENT_LANGUAGE=id
CONTENT_COUNTRY=ID

# ─── Paths ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
CACHE_DIR=./cache
MEMORY_DIR=./memory
LOG_DIR=./logs

# ─── Cache ────────────────────────────────────────────────────────────────────
# Hasil YouTube API & LLM di-cache per hari untuk hemat kuota
CACHE_TTL_HOURS=6

# ─── Cleanup ──────────────────────────────────────────────────────────────────
REJECTED_VIDEO_TTL_DAYS=7
