# ─── Mode ────────────────────────────────────────────────────────────────────
DRY_RUN=true
NODE_ENV=development

# ─── AI — OpenRouter ─────────────────────────────────────────────────────────
# Dapatkan di: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model LLM per-agent (default: anthropic/claude-3-haiku jika tidak di-set)
# Lihat semua model di: https://openrouter.ai/models
CLIP_PLANNER_MODEL=anthropic/claude-3-5-sonnet
METADATA_MODEL=anthropic/claude-3-haiku

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Buat bot via @BotFather → dapatkan token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Kirim pesan ke @userinfobot untuk mendapatkan chat ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── PHASE 2: Advanced Agents (Multi-Agent Scoring) ──────────────────────────
# Enable/disable advanced processing agents
# Set to 'false' to disable (default: enabled)
ENABLE_MOMENT_SCORING=true
ENABLE_CRITIC=true
ENABLE_CAPTION_AGENT=true
ENABLE_REFRAME_AGENT=true

# ─── Whisper (Transcription) ─────────────────────────────────────────────────
# Model size: tiny, base, small, medium, large
# Larger = more accurate but slower. 'base' is good balance.
WHISPER_MODEL=base

# ─── Scene Detection ─────────────────────────────────────────────────────────
# Threshold: 27.0 default. Lower = more sensitive (more scenes detected)
SCENE_DETECT_THRESHOLD=27.0

# ─── yt-dlp (Video Download) ─────────────────────────────────────────────────
# Format string for yt-dlp. Default downloads best quality MP4.
YTDLP_FORMAT=bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best

# ─── Retry & Timeout ──────────────────────────────────────────────────────────
MAX_RETRY=3
TIMEOUT_DEFAULT=1800000

# ─── Video Config ─────────────────────────────────────────────────────────────
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30

# ─── Paths ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
CACHE_DIR=./cache
MEMORY_DIR=./memory
LOG_DIR=./logs

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL_HOURS=6

# ─── Cleanup ──────────────────────────────────────────────────────────────────
REJECTED_VIDEO_TTL_DAYS=7

# ═══════════════════════════════════════════════════════════════════════════════
# LEGACY CONFIG (for original UGC generator pipeline - disabled by default)
# ═══════════════════════════════════════════════════════════════════════════════

