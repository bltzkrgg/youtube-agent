# ─── Mode ────────────────────────────────────────────────────────────────────
DRY_RUN=true
NODE_ENV=development

# ─── AI (OpenRouter) ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3-haiku

# ─── Edge TTS (Voiceover) — gratis, tidak butuh API key ──────────────────────
# Suara Indonesia: id-ID-ArdiNeural (maskulin), id-ID-GadisNeural (feminin)
TTS_VOICE=id-ID-ArdiNeural
# Rate: +0% normal, +10% lebih cepat, -10% lebih lambat
TTS_RATE=+0%

# ─── Pexels (Stock Footage) ───────────────────────────────────────────────────
PEXELS_API_KEY=your_pexels_api_key_here

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Retry & Timeout ──────────────────────────────────────────────────────────
MAX_RETRY=3
TIMEOUT_RESEARCH=300000
TIMEOUT_CLIP=1800000
TIMEOUT_UPLOAD=600000
TIMEOUT_DEFAULT=60000

# ─── Video Config ─────────────────────────────────────────────────────────────
VIDEO_MAX_DURATION=60
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30

# ─── Content ──────────────────────────────────────────────────────────────────
CONTENT_NICHE=fakta unik indonesia
CONTENT_LANGUAGE=id
CONTENT_COUNTRY=ID

# ─── Paths ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
CACHE_DIR=./cache
MEMORY_DIR=./memory
LOG_DIR=./logs

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL_HOURS=6

# ─── Cleanup ──────────────────────────────────────────────────────────────────
REJECTED_VIDEO_TTL_DAYS=7
